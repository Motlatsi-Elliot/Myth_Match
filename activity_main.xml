<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <!--Welcome Screen-->
    <ScrollView
        android:id="@+id/welcomeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:layout_gravity="center"
        android:layout_marginTop="100dp"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="30dp"
            android:paddingBottom="32dp">

            <!-- App Title-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Life Hack \n OR \n Urban Myth ?"
                android:textColor="#fff"
                android:textSize="28dp"
                android:textStyle="bold"
                android:layout_marginBottom="15dp"/>

            <!-- App description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Test your knowledge — Learn useful and Safe Real World shortcuts, Separate Life hacks from Urban Myths"
                android:textColor="#808080"
                android:textSize="17sp"
                android:lineSpacingMultiplier="1.5"
                android:textStyle="bold|italic"
                android:layout_marginBottom="28dp"/>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/bg_card2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10"
                        android:textColor="#F0C040"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Questions"
                        android:textColor="#7A8299"
                        android:textSize="15sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:background="@drawable/bg_card2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆"
                        android:textSize="20sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ranked"
                        android:textColor="#7A8299"
                        android:textSize="15sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Start Button -->
            <Button
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="61dp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_gradient"
                android:gravity="center"
                android:text="Start Quiz"
                android:textAlignment="center"
                android:textColor="#fff"
                android:textSize="21sp"
                android:textStyle="bold|normal" />
        </LinearLayout>
    </ScrollView>*/

    <!--FlashCard QUESTION Screen-->

    <LinearLayout
        android:id="@+id/questionScreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <!-- Progress Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvScoreLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score: 0"
                android:textColor="#F0C040"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Flashcard -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_green_chip"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:text="🔍 HACK OR MYTH?"
                android:textColor="#3DE4A4"
                android:textSize="13.5dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.4"
                android:text="The average person's left hand does 56% of 't."
                android:textColor="#FFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Hack & Myth Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:id="@+id/btnHack"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_hack"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Hack"
                    android:textColor="#3DE4A4"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="True"
                    android:textColor="#803DE4A4"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnMyth"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_myth"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❌ Myth"
                    android:textColor="#FF5E6C"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="False!"
                    android:textColor="#80FF5E6C"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Feedback Box -->
        <LinearLayout
            android:id="@+id/feedbackBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_feedback"
            android:orientation="horizontal"
            android:padding="14dp"
            android:visibility="visible">


            <TextView
                android:id="@+id/tvFeedbackText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The average person's left hand does 56% of the typing (when using the proper position of the hands on the keyboard; Hunting and pecking doesn't count!)."
                android:textColor="#3DE4A4"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Next Button -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_gradient"
            android:gravity="center"
            android:stateListAnimator="@null"
            android:text="Next Question"
            android:textColor="#fff"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="visible" />

    </LinearLayout>


        <!-- SCORE Screen-->
    <ScrollView
        android:id="@+id/screenScore"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="110dp"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <!-- Badge -->
            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="18dp"
                android:text="Master Hacker! 🏆"
                android:textColor="#F0C040"
                android:textSize="25sp"
                android:textStyle="bold"/>

            <!-- Sub Text -->
            <TextView
                android:id="@+id/tvScoreSub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="You can spot an urban myth from a mile away."
                android:textColor="#fff"
                android:textSize="18sp"
                android:layout_marginTop="8dp"
                android:textStyle="italic"
                android:layout_marginBottom="28dp"/>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/bg_card2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/tvCorrectCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7"
                        android:textColor="#3DE4A4"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Correct"
                        android:textColor="#808080"
                        android:textSize="15sp"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/bg_card2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">
                    <TextView
                        android:id="@+id/tvWrongCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textColor="#FF5E6C"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wrong"
                        android:textColor="#808080"
                        android:textSize="15sp"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Review Button -->
            <Button
                android:id="@+id/btnReview"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="45dp"
                android:layout_gravity="center"
                android:paddingTop="18dp"
                android:textAlignment="center"
                android:background="@drawable/bg_card2"
                android:text="📋  Review Answers"
                android:textColor="#EEF0F6"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <!-- Play Again Button -->
            <Button
                android:id="@+id/btnPlayAgain"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:layout_gravity="center"
                android:paddingTop="18dp"
                android:textAlignment="center"
                android:background="@drawable/bg_gradient"
                android:text="🔄  Play Again"
                android:textColor="#0D0F14"
                android:textSize="18sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </ScrollView>

    <!--SCREEN 4 — REVIEW -->
    <ScrollView
        android:id="@+id/screenReview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/reviewList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Answer Review"
                android:textColor="#EEF0F6"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingTop="20dp"
                android:paddingBottom="16dp"/>

            <!-- Return back to score Button -->

            <Button
                android:id="@+id/btnBackToScore"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_card2"
                android:text="Back to Score"
                android:textColor="#fff"
                android:textAlignment="center"
                android:paddingTop="15sp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>